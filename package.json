{
  "name": "evidence-collecting",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "husky",
    "lint": "eslint src/",
    "format": "prettier --write .",
    "stylelint": "stylelint \"src/**/*.css\" \"src/**/*.svelte\""
  },
  "lint-staged": {
    "*.{js,svelte}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.css": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.{html,json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@csstools/postcss-global-data": "^4.0.0",
    "@eslint/js": "^10.0.1",
    "@sveltejs/adapter-auto": "^7.0.0",
    "@sveltejs/kit": "^2.49.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.0.0",
    "eslint-plugin-svelte": "^3.16.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.6",
    "postcss-csso": "^6.0.1",
    "postcss-preset-env": "^11.1.3",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "stylelint": "^17.6.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-standard": "^40.0.0",
    "svelte": "^5.45.6",
    "svelte-preprocess": "^6.0.3",
    "vite": "^7.2.6"
  },
  "dependencies": {
    "sveltekit-superforms": "^2.30.0",
    "zod": "^3.25.76"
  }
}
